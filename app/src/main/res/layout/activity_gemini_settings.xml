<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/m3_surface"
    android:padding="24dp">

    <TextView android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Abilita Gemini AI"
        android:textColor="@color/text_on_card"
        android:textSize="22sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Inserisci una chiave API di Google AI Studio per attivare il briefing mattutino intelligente, la summarizzazione delle notifiche e la classificazione automatica delle app."
        android:textColor="@color/text_on_card_secondary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-light"
        android:lineSpacingMultiplier="1.5"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        android:id="@+id/tvDesc"
        app:layout_constraintStart_toStartOf="parent"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilApiKey"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toBottomOf="@id/tvDesc"
        app:layout_constraintStart_toStartOf="parent"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etApiKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Incolla la tua API key"
            android:inputType="textVisiblePassword"
            android:fontFamily="monospace"
            android:textSize="13sp"/>
    </com.google.android.material.textfield.TextInputLayout>

    <Button android:id="@+id/btnGetKey"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Ottieni chiave gratuita su AI Studio →"
        android:backgroundTint="@color/m3_primary_container"
        android:textColor="@color/m3_on_primary_container"
        android:textSize="13sp"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/tilApiKey"
        app:layout_constraintStart_toStartOf="parent"/>

    <Button android:id="@+id/btnSaveKey"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Salva e attiva"
        android:backgroundTint="@color/m3_primary"
        android:textColor="@color/m3_on_primary"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnGetKey"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView android:id="@+id/btnClose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chiudi"
        android:textColor="@color/text_on_card_secondary"
        android:textSize="14sp"
        android:padding="8dp"
        android:layout_marginTop="12dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/btnSaveKey"
        app:layout_constraintStart_toStartOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
