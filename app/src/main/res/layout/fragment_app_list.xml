<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_container_lowest">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface_container_low"
        android:paddingStart="24dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvAllAppsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TUTTE LE APP"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp"
            android:letterSpacing="0.20"
            android:fontFamily="sans-serif-medium"
            android:paddingBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_search_bar"
            android:paddingHorizontal="18dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔍" android:textSize="16sp" android:layout_marginEnd="10dp"/>

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Cerca app…"
                android:textColorHint="#55FFFFFF"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"/>
        </LinearLayout>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAllApps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingTop="4dp"
        android:paddingBottom="185dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
