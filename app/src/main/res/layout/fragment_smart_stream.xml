<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="145dp">

        <!-- Status bar spacer -->
        <View android:id="@+id/statusBarSpacer"
            android:layout_width="match_parent"
            android:layout_height="0dp"/>

        <!-- ══ HEADER su wallpaper con scrim ══ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- SCRIM gradient — caratteristica iconica di Aviate -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_stream_scrim"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="22dp"
                android:paddingEnd="18dp"
                android:paddingTop="12dp"
                android:paddingBottom="20dp">

                <!-- Ora — grande, thin, sinistra -->
                <TextView android:id="@+id/tvStreamTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="09:41"
                    android:textColor="#FFFFFF"
                    android:textSize="92sp"
                    android:fontFamily="sans-serif-thin"
                    android:letterSpacing="-0.05"
                    android:includeFontPadding="false"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <!-- FAB Modalità — destra, allineato verticalmente all'orologio -->
                <LinearLayout android:id="@+id/btnModeSelector"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_mode_fab"
                    android:paddingHorizontal="13dp"
                    android:paddingVertical="9dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="2dp"
                    app:layout_constraintTop_toTopOf="@id/tvStreamTime"
                    app:layout_constraintBottom_toBottomOf="@id/tvStreamTime"
                    app:layout_constraintEnd_toEndOf="parent">

                    <TextView android:id="@+id/tvModeEmoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="☀️"
                        android:textSize="16sp"/>

                    <TextView android:id="@+id/tvModeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mattina"
                        android:textColor="#1C1B1F"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginStart="5dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" ▾"
                        android:textColor="#1C1B1F"
                        android:textSize="10sp"
                        android:alpha="0.5"/>
                </LinearLayout>

                <!-- Data -->
                <TextView android:id="@+id/tvStreamDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lunedì, 5 Maggio"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-light"
                    android:letterSpacing="0.01"
                    android:layout_marginTop="0dp"
                    app:layout_constraintTop_toBottomOf="@id/tvStreamTime"
                    app:layout_constraintStart_toStartOf="parent"/>

                <!-- Saluto contestuale — esattamente come Aviate -->
                <TextView android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Buongiorno"
                    android:textColor="#99FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-light"
                    android:letterSpacing="0.01"
                    android:layout_marginTop="1dp"
                    app:layout_constraintTop_toBottomOf="@id/tvStreamDate"
                    app:layout_constraintStart_toStartOf="parent"/>

                <!-- Pills modalità orizzontali — stile Aviate -->
                <HorizontalScrollView android:id="@+id/pillsScroll"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:overScrollMode="never"
                    android:layout_marginTop="14dp"
                    app:layout_constraintTop_toBottomOf="@id/tvGreeting"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout android:id="@+id/llModePills"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"/>
                </HorizontalScrollView>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </FrameLayout>


        <!-- ══ AI BRIEFING — riassunto mattutino Gemini ══ -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/cardAiBriefing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            app:cardBackgroundColor="#EEF2FF"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            app:strokeWidth="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp"
                android:gravity="top">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="✨" android:textSize="18sp" android:layout_marginEnd="12dp"
                    android:layout_marginTop="2dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="GEMINI" android:textColor="#3949AB"
                        android:textSize="9sp" android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.12" android:layout_marginBottom="3dp"/>
                    <TextView android:id="@+id/tvAiBriefing"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textColor="@color/text_on_card"
                        android:textSize="14sp" android:fontFamily="sans-serif-light"
                        android:lineSpacingMultiplier="1.4"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ AI NOTIFICA PRIORITARIA — ranker smart ══ -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/cardSmartNotif"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            app:cardBackgroundColor="#FFFBF0"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp"
                android:gravity="center_vertical">
                <FrameLayout android:layout_width="38dp" android:layout_height="38dp"
                    android:background="@drawable/bg_info_icon_orange">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="🔔" android:textSize="16sp"/>
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView android:id="@+id/tvSmartNotifTitle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_on_card"
                        android:textSize="14sp" android:fontFamily="sans-serif-medium"
                        android:maxLines="1" android:ellipsize="end"/>
                    <TextView android:id="@+id/tvSmartNotifText"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_on_card_secondary"
                        android:textSize="12sp" android:fontFamily="sans-serif-light"
                        android:maxLines="2" android:ellipsize="end"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ PATTERN APP — routine rilevate ══ -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/cardPatterns"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/card_white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ROUTINE RILEVATE"
                    android:textColor="@color/text_on_card_secondary"
                    android:textSize="9sp" android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.12" android:layout_marginBottom="8dp"/>
                <LinearLayout android:id="@+id/llPatterns"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ WEEKLY DIGEST — riepilogo settimanale ══ -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/cardWeeklyDigest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            app:cardBackgroundColor="#F3E8FF"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp"
                android:gravity="top">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📊" android:textSize="22sp" android:layout_marginEnd="12dp"
                    android:layout_marginTop="2dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="QUESTA SETTIMANA"
                        android:textColor="#6A1B9A"
                        android:textSize="9sp" android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.12" android:layout_marginBottom="3dp"/>
                    <TextView android:id="@+id/tvWeeklyDigest"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textColor="@color/text_on_card"
                        android:textSize="13sp" android:fontFamily="sans-serif-light"
                        android:lineSpacingMultiplier="1.4"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ CHIAMATE PERSE ══ -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/cardMissedCalls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/card_call_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp"
                android:gravity="center_vertical">
                <FrameLayout android:layout_width="38dp" android:layout_height="38dp"
                    android:background="@drawable/bg_info_icon_orange">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="📞" android:textSize="16sp"/>
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="CHIAMATA PERSA"
                        android:textColor="#C62828" android:textSize="9sp"
                        android:fontFamily="sans-serif-medium" android:letterSpacing="0.10"/>
                    <TextView android:id="@+id/tvMissedCallsCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_on_card"
                        android:textSize="15sp" android:fontFamily="sans-serif"
                        android:maxLines="1" android:ellipsize="end"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ SMS NON LETTI ══ -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/cardUnreadSms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/card_sms_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp"
                android:gravity="center_vertical">
                <FrameLayout android:layout_width="38dp" android:layout_height="38dp"
                    android:background="@drawable/bg_info_icon_blue">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="💬" android:textSize="16sp"/>
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="MESSAGGI NON LETTI"
                        android:textColor="#1565C0" android:textSize="9sp"
                        android:fontFamily="sans-serif-medium" android:letterSpacing="0.10"/>
                    <TextView android:id="@+id/tvUnreadSmsCount"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textColor="@color/text_on_card" android:textSize="14sp"
                        android:fontFamily="sans-serif" android:maxLines="1" android:ellipsize="end"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ AUTO BLUETOOTH ══ -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/cardCarBt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/card_car_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp"
                android:gravity="center_vertical">
                <FrameLayout android:layout_width="38dp" android:layout_height="38dp"
                    android:background="@drawable/bg_info_icon_green">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="🚗" android:textSize="16sp"/>
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="IN AUTO"
                        android:textColor="#1B7B45" android:textSize="9sp"
                        android:fontFamily="sans-serif-medium" android:letterSpacing="0.10"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Navigazione e musica in primo piano"
                        android:textColor="@color/text_on_card" android:textSize="14sp"
                        android:fontFamily="sans-serif"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ METEO ══ -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/cardWeather"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/card_weather_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            app:strokeWidth="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="18dp"
                android:gravity="center_vertical">

                <TextView android:id="@+id/tvWeatherEmoji"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="☀️" android:textSize="48sp"/>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:layout_marginStart="16dp">
                    <TextView android:id="@+id/tvWeatherTemp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="22°"
                        android:textColor="@color/text_on_card"
                        android:textSize="32sp"
                        android:fontFamily="sans-serif-thin"
                        android:includeFontPadding="false"/>
                    <TextView android:id="@+id/tvWeatherDesc"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Sereno"
                        android:textColor="@color/text_on_card_secondary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-light"/>
                    <TextView android:id="@+id/tvWeatherFeels"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/accent"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-light"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="OGGI"
                    android:textColor="@color/accent"
                    android:textSize="9sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.14"
                    android:layout_gravity="top"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ CALENDARIO ══ -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/cardCalendar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/card_calendar_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            app:strokeWidth="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp"
                android:gravity="center_vertical">
                <FrameLayout android:layout_width="42dp" android:layout_height="42dp"
                    android:background="@drawable/bg_info_icon_blue">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="📅" android:textSize="20sp"/>
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:layout_marginStart="14dp">
                    <TextView android:id="@+id/tvEventTitle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_on_card"
                        android:textSize="15sp" android:fontFamily="sans-serif-medium"
                        android:maxLines="1" android:ellipsize="end"/>
                    <TextView android:id="@+id/tvEventTime"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/accent"
                        android:textSize="12sp" android:fontFamily="sans-serif-light"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ MUSICA ══ -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/cardMusic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/card_music_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp"
                android:gravity="center_vertical">
                <FrameLayout android:layout_width="42dp" android:layout_height="42dp"
                    android:background="@drawable/bg_info_icon_purple">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="🎵" android:textSize="18sp"/>
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView android:id="@+id/tvMusicTitle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_on_card" android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1" android:ellipsize="end"/>
                    <TextView android:id="@+id/tvMusicArtist"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_on_card_secondary" android:textSize="12sp"
                        android:fontFamily="sans-serif-light"
                        android:maxLines="1" android:ellipsize="end"/>
                </LinearLayout>
                <TextView android:id="@+id/btnMusicPlayPause"
                    android:layout_width="40dp" android:layout_height="40dp"
                    android:text="⏸" android:textSize="20sp" android:gravity="center"
                    android:textColor="@color/accent"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ APP SUGGERITE ══ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/card_white"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            app:strokeWidth="0dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:paddingBottom="8dp">

                <TextView android:id="@+id/tvSuggestedTitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:paddingBottom="8dp"
                    android:text="APP SUGGERITE"
                    android:textColor="@color/text_on_card_secondary"
                    android:textSize="9sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.14"/>

                <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvStreamApps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="4dp"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    android:nestedScrollingEnabled="false"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ BATTERIA + WI-FI affiancate ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp"
            android:layout_marginBottom="8dp"
            android:baselineAligned="false">

            <!-- Batteria -->
            <com.google.android.material.card.MaterialCardView android:id="@+id/sectionBattery"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="4dp"
                app:cardBackgroundColor="@color/card_battery_bg"
                app:cardCornerRadius="16dp" app:cardElevation="2dp" app:strokeWidth="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🔋" android:textSize="14sp" android:layout_marginEnd="6dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="BATTERIA" android:textColor="@color/text_on_card_secondary"
                            android:textSize="9sp" android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.08"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvBatteryLevel"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="#1B7B45"
                        android:textSize="30sp" android:fontFamily="sans-serif-thin"
                        android:includeFontPadding="false"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Wi-Fi -->
            <com.google.android.material.card.MaterialCardView android:id="@+id/sectionWifi"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="4dp"
                app:cardBackgroundColor="@color/card_wifi_bg"
                app:cardCornerRadius="16dp" app:cardElevation="2dp" app:strokeWidth="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📶" android:textSize="14sp" android:layout_marginEnd="6dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="RETE" android:textColor="@color/text_on_card_secondary"
                            android:textSize="9sp" android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.08"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvWifiName"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="—" android:textColor="#1565C0"
                        android:textSize="16sp" android:fontFamily="sans-serif-light"
                        android:maxLines="1" android:ellipsize="end"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ══ CUFFIE ══ -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/cardHeadphones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/card_music_bg"
            app:cardCornerRadius="16dp" app:cardElevation="2dp" app:strokeWidth="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp"
                android:gravity="center_vertical">
                <FrameLayout android:layout_width="38dp" android:layout_height="38dp"
                    android:background="@drawable/bg_info_icon_purple">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="🎧" android:textSize="16sp"/>
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="CUFFIE CONNESSE" android:textColor="#6A1B9A"
                        android:textSize="9sp" android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.10"/>
                    <TextView android:id="@+id/tvHeadphonesName"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_on_card" android:textSize="14sp"
                        android:fontFamily="sans-serif"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
