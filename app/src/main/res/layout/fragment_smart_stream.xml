<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:overScrollMode="never"
    android:fillViewport="true"
    android:background="@color/surface_container_lowest">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="185dp">

        <!-- ══ HEADER M3: orologio + data + FAB modalità ══ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface_container_low"
            android:paddingStart="28dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <!-- Spacer status bar -->
            <View android:id="@+id/statusBarSpacer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <!-- ORA: thin enorme -->
            <TextView
                android:id="@+id/tvStreamTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="09:41"
                android:textColor="@color/text_primary"
                android:textSize="80sp"
                android:fontFamily="sans-serif-thin"
                android:includeFontPadding="false"
                android:letterSpacing="-0.04"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/statusBarSpacer"
                app:layout_constraintStart_toStartOf="parent"/>

            <!-- FAB MODALITÀ — in alto a destra, Material3 style -->
            <LinearLayout
                android:id="@+id/btnModeSelector"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_mode_fab"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:clickable="true"
                android:focusable="true"
                android:elevation="4dp"
                app:layout_constraintTop_toBottomOf="@id/statusBarSpacer"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="@id/tvStreamTime"
                app:layout_constraintTop_toTopOf="@id/tvStreamTime">

                <TextView
                    android:id="@+id/tvModeEmoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☀️"
                    android:textSize="18sp"/>

                <TextView
                    android:id="@+id/tvModeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mattina"
                    android:textColor="@color/md_on_primary_container"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="6dp"/>

                <!-- Chevron giù -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  ▾"
                    android:textColor="@color/md_on_primary_container"
                    android:textSize="11sp"
                    android:alpha="0.7"/>

            </LinearLayout>

            <!-- DATA -->
            <TextView
                android:id="@+id/tvStreamDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Martedì, 28 Aprile"
                android:textColor="@color/text_tertiary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.03"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="18dp"
                app:layout_constraintTop_toBottomOf="@id/tvStreamTime"
                app:layout_constraintStart_toStartOf="parent"/>

            <!-- PILLS MODALITÀ: scroll orizzontale sotto la data -->
            <HorizontalScrollView
                android:id="@+id/pillsScroll"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:overScrollMode="never"
                android:layout_marginStart="-4dp"
                app:layout_constraintTop_toBottomOf="@id/tvStreamDate"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:id="@+id/llModePills"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="4dp"
                    android:paddingEnd="16dp"/>

            </HorizontalScrollView>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ══ SEZIONE INFO: card M3 con margini e angoli arrotondati ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp">

            <!-- CARD BATTERIA -->
            <LinearLayout
                android:id="@+id/sectionBattery"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="18dp"
                android:background="@drawable/bg_info_row"
                android:layout_marginBottom="8dp"
                android:elevation="1dp">

                <FrameLayout android:layout_width="40dp" android:layout_height="40dp"
                    android:background="@drawable/bg_info_icon_green">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="🔋" android:textSize="18sp"/>
                </FrameLayout>

                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Batteria"
                    android:textColor="@color/text_primary" android:textSize="15sp"
                    android:fontFamily="sans-serif" android:layout_marginStart="16dp"/>

                <TextView android:id="@+id/tvBatteryLevel"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textColor="@color/text_primary"
                    android:textSize="22sp" android:fontFamily="sans-serif-thin"/>
            </LinearLayout>

            <!-- CARD WI-FI -->
            <LinearLayout
                android:id="@+id/sectionWifi"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="18dp"
                android:background="@drawable/bg_info_row"
                android:layout_marginBottom="8dp"
                android:elevation="1dp">

                <FrameLayout android:layout_width="40dp" android:layout_height="40dp"
                    android:background="@drawable/bg_info_icon_blue">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="📶" android:textSize="18sp"/>
                </FrameLayout>

                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Wi-Fi"
                    android:textColor="@color/text_primary" android:textSize="15sp"
                    android:fontFamily="sans-serif" android:layout_marginStart="16dp"/>

                <TextView android:id="@+id/tvWifiName"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textColor="@color/text_secondary"
                    android:textSize="14sp" android:fontFamily="sans-serif-light"
                    android:maxWidth="140dp" android:maxLines="1" android:ellipsize="end"/>
            </LinearLayout>

            <!-- CARD CUFFIE (visibile solo se collegate) -->
            <LinearLayout
                android:id="@+id/sectionHeadphones"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="18dp"
                android:background="@drawable/bg_info_row"
                android:layout_marginBottom="8dp"
                android:elevation="1dp"
                android:visibility="gone">

                <FrameLayout android:layout_width="40dp" android:layout_height="40dp"
                    android:background="@drawable/bg_info_icon_purple">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="🎧" android:textSize="18sp"/>
                </FrameLayout>

                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Cuffie"
                    android:textColor="@color/text_primary" android:textSize="15sp"
                    android:fontFamily="sans-serif" android:layout_marginStart="16dp"/>

                <TextView android:id="@+id/tvHeadphonesName"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Connesse" android:textColor="@color/accent"
                    android:textSize="14sp" android:fontFamily="sans-serif-light"/>
            </LinearLayout>

            <!-- divisore invisibile per headphones -->
            <View android:id="@+id/dividerHeadphones"
                android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

        </LinearLayout>

        <!-- ══ APP SUGGERITE ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp">

            <TextView android:id="@+id/tvSuggestedTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BUONA MATTINA"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp"
                android:letterSpacing="0.20"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="4dp"
                android:paddingBottom="10dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvStreamApps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:overScrollMode="never"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
