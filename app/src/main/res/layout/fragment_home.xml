<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:overScrollMode="never"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="680dp">

        <!-- ── OROLOGIO centrato, font ultra-thin ── -->
        <LinearLayout android:id="@+id/clockBlock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="72dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="09:41"
                android:textColor="#FFFFFF"
                android:textSize="104sp"
                android:fontFamily="sans-serif-thin"
                android:letterSpacing="-0.05"
                android:includeFontPadding="false"
                android:shadowColor="#88000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="16"/>

            <TextView android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LUNEDÌ, 5 MAGGIO"
                android:textColor="#BBFFFFFF"
                android:textSize="11sp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.18"
                android:textAllCaps="true"
                android:layout_marginTop="4dp"
                android:shadowColor="#66000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="6"/>
        </LinearLayout>

        <!-- ── GOOGLE SEARCH BAR — frosted, stile Aviate ── -->
        <LinearLayout android:id="@+id/searchBar"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_search_home"
            android:layout_marginHorizontal="22dp"
            android:layout_marginTop="18dp"
            android:paddingStart="16dp"
            android:paddingEnd="10dp"
            android:clickable="true"
            android:focusable="true"
            android:elevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/clockBlock"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="G"
                android:textColor="#4285F4"
                android:textSize="17sp"
                android:fontFamily="sans-serif-bold"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cerca o digita un URL"
                android:textColor="#70FFFFFF"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:layout_marginStart="10dp"
                android:singleLine="true"/>

            <TextView android:id="@+id/searchMic"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="🎤"
                android:textSize="16sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_icon_press"/>
        </LinearLayout>

        <!-- ── GRIGLIA PREFERITI (8 app più usate) ── -->
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvFavorites"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:paddingTop="6dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            app:layout_constraintTop_toBottomOf="@id/searchBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ── SEZIONE WIDGET — frosted glass ── -->
        <LinearLayout android:id="@+id/widgetSection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="14dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_widget_area"
            android:padding="14dp"
            android:elevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/rvFavorites"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="WIDGET"
                    android:textColor="#70FFFFFF"
                    android:textSize="9sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.18"/>

                <TextView android:id="@+id/btnAddWidget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+ Aggiungi"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_widget_add_btn"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/widgetContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <LinearLayout android:id="@+id/widgetPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_widget_placeholder">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⊞"
                    android:textColor="#80FFFFFF"
                    android:textSize="20sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tieni premuto per aggiungere widget"
                    android:textColor="#60FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginTop="3dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ── HINT swipe ── -->
        <TextView android:id="@+id/tvSwipeHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="◂ STREAM    ·    APP ▸"
            android:textColor="#55FFFFFF"
            android:textSize="9sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.14"
            android:paddingBottom="185dp"
            android:shadowColor="#66000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="4"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
