<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/card_white">

    <!-- Handle bar M3 -->
    <View android:layout_width="36dp" android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp" android:layout_marginBottom="16dp"
        android:background="#D0C7D0"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="CAMBIA MODALITÀ"
        android:textColor="@color/text_on_card_secondary"
        android:textSize="9sp" android:letterSpacing="0.18"
        android:fontFamily="sans-serif-medium"
        android:paddingHorizontal="20dp" android:paddingBottom="8dp"/>

    <LinearLayout android:id="@+id/itemMorning"
        android:layout_width="match_parent" android:layout_height="54dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="20dp" android:clickable="true" android:focusable="true"
        android:background="@drawable/bg_app_row_press">
        <TextView android:layout_width="28dp" android:layout_height="wrap_content"
            android:text="☀️" android:textSize="20sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Buongiorno" android:textColor="@color/text_on_card"
            android:textSize="15sp" android:fontFamily="sans-serif" android:layout_marginStart="14dp"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/itemCommute"
        android:layout_width="match_parent" android:layout_height="54dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="20dp" android:clickable="true" android:focusable="true"
        android:background="@drawable/bg_app_row_press">
        <TextView android:layout_width="28dp" android:layout_height="wrap_content"
            android:text="🚌" android:textSize="20sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="In viaggio" android:textColor="@color/text_on_card"
            android:textSize="15sp" android:fontFamily="sans-serif" android:layout_marginStart="14dp"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/itemWork"
        android:layout_width="match_parent" android:layout_height="54dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="20dp" android:clickable="true" android:focusable="true"
        android:background="@drawable/bg_app_row_press">
        <TextView android:layout_width="28dp" android:layout_height="wrap_content"
            android:text="💼" android:textSize="20sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Lavoro" android:textColor="@color/text_on_card"
            android:textSize="15sp" android:fontFamily="sans-serif" android:layout_marginStart="14dp"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/itemLunch"
        android:layout_width="match_parent" android:layout_height="54dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="20dp" android:clickable="true" android:focusable="true"
        android:background="@drawable/bg_app_row_press">
        <TextView android:layout_width="28dp" android:layout_height="wrap_content"
            android:text="🍽️" android:textSize="20sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Pausa pranzo" android:textColor="@color/text_on_card"
            android:textSize="15sp" android:fontFamily="sans-serif" android:layout_marginStart="14dp"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/itemEvening"
        android:layout_width="match_parent" android:layout_height="54dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="20dp" android:clickable="true" android:focusable="true"
        android:background="@drawable/bg_app_row_press">
        <TextView android:layout_width="28dp" android:layout_height="wrap_content"
            android:text="🌆" android:textSize="20sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Buonasera" android:textColor="@color/text_on_card"
            android:textSize="15sp" android:fontFamily="sans-serif" android:layout_marginStart="14dp"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/itemNight"
        android:layout_width="match_parent" android:layout_height="54dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="20dp" android:clickable="true" android:focusable="true"
        android:background="@drawable/bg_app_row_press">
        <TextView android:layout_width="28dp" android:layout_height="wrap_content"
            android:text="🌙" android:textSize="20sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Buonanotte" android:textColor="@color/text_on_card"
            android:textSize="15sp" android:fontFamily="sans-serif" android:layout_marginStart="14dp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/m3_outline_variant" android:layout_marginVertical="6dp"
        android:layout_marginHorizontal="16dp"/>

    <LinearLayout android:id="@+id/itemAuto"
        android:layout_width="match_parent" android:layout_height="54dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="20dp" android:clickable="true" android:focusable="true"
        android:background="@drawable/bg_app_row_press">
        <TextView android:layout_width="28dp" android:layout_height="wrap_content"
            android:text="🔄" android:textSize="20sp"/>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginStart="14dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Automatico" android:textColor="@color/text_on_card"
                android:textSize="15sp" android:fontFamily="sans-serif"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Segue ora del giorno e posizione"
                android:textColor="@color/text_on_card_secondary"
                android:textSize="11sp" android:fontFamily="sans-serif-light"/>
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="16dp"/>
</LinearLayout>
