<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- DOCK fisso in basso con gradiente -->
    <LinearLayout
        android:id="@+id/dockContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_dock"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Indicatori pagina -->
        <LinearLayout
            android:id="@+id/pageIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="center_horizontal"
            android:paddingTop="10dp"
            android:paddingBottom="6dp"/>

        <!-- 4 icone dock -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:paddingBottom="4dp">

            <LinearLayout android:id="@+id/dockSlot1"
                android:layout_width="0dp" android:layout_height="72dp"
                android:layout_weight="1" android:gravity="center"
                android:background="@drawable/bg_dock_item"
                android:clickable="true" android:focusable="true">
                <ImageView android:id="@+id/dockIcon1"
                    android:layout_width="50dp" android:layout_height="50dp"
                    android:scaleType="fitCenter"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/dockSlot2"
                android:layout_width="0dp" android:layout_height="72dp"
                android:layout_weight="1" android:gravity="center"
                android:background="@drawable/bg_dock_item"
                android:clickable="true" android:focusable="true">
                <ImageView android:id="@+id/dockIcon2"
                    android:layout_width="50dp" android:layout_height="50dp"
                    android:scaleType="fitCenter"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/dockSlot3"
                android:layout_width="0dp" android:layout_height="72dp"
                android:layout_weight="1" android:gravity="center"
                android:background="@drawable/bg_dock_item"
                android:clickable="true" android:focusable="true">
                <ImageView android:id="@+id/dockIcon3"
                    android:layout_width="50dp" android:layout_height="50dp"
                    android:scaleType="fitCenter"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/dockSlot4"
                android:layout_width="0dp" android:layout_height="72dp"
                android:layout_weight="1" android:gravity="center"
                android:background="@drawable/bg_dock_item"
                android:clickable="true" android:focusable="true">
                <ImageView android:id="@+id/dockIcon4"
                    android:layout_width="50dp" android:layout_height="50dp"
                    android:scaleType="fitCenter"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Spacer navigation bar (impostato via codice in MainActivity) -->
        <View android:id="@+id/navBarSpacer"
            android:layout_width="match_parent"
            android:layout_height="0dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
