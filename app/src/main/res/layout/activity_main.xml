<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- DOCK — vetro bianco, stile Aviate originale -->
    <LinearLayout android:id="@+id/dockContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_dock"
        android:clickable="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Indicatori pagina — piccoli, centrati, minimalisti come Aviate -->
        <LinearLayout android:id="@+id/pageIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="center_horizontal"
            android:paddingTop="10dp"
            android:paddingBottom="2dp"/>

        <!-- 4 slot dock — icone 52dp -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="2dp"
            android:paddingTop="4dp"
            android:paddingBottom="6dp">

            <!-- Slot 1 -->
            <FrameLayout android:layout_width="0dp" android:layout_height="68dp"
                android:layout_weight="1">
                <LinearLayout android:id="@+id/dockSlot1"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:gravity="center" android:background="@drawable/bg_dock_item"
                    android:clickable="true" android:focusable="true">
                    <ImageView android:id="@+id/dockIcon1"
                        android:layout_width="52dp" android:layout_height="52dp"
                        android:scaleType="centerInside"/>
                </LinearLayout>
                <TextView android:id="@+id/dockBadge1"
                    android:layout_width="17dp" android:layout_height="17dp"
                    android:layout_gravity="top|end" android:layout_margin="7dp"
                    android:background="@drawable/bg_badge"
                    android:textColor="#FFFFFF" android:textSize="9sp"
                    android:fontFamily="sans-serif-bold" android:gravity="center"
                    android:visibility="gone"/>
            </FrameLayout>

            <!-- Slot 2 -->
            <FrameLayout android:layout_width="0dp" android:layout_height="68dp"
                android:layout_weight="1">
                <LinearLayout android:id="@+id/dockSlot2"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:gravity="center" android:background="@drawable/bg_dock_item"
                    android:clickable="true" android:focusable="true">
                    <ImageView android:id="@+id/dockIcon2"
                        android:layout_width="52dp" android:layout_height="52dp"
                        android:scaleType="centerInside"/>
                </LinearLayout>
                <TextView android:id="@+id/dockBadge2"
                    android:layout_width="17dp" android:layout_height="17dp"
                    android:layout_gravity="top|end" android:layout_margin="7dp"
                    android:background="@drawable/bg_badge"
                    android:textColor="#FFFFFF" android:textSize="9sp"
                    android:fontFamily="sans-serif-bold" android:gravity="center"
                    android:visibility="gone"/>
            </FrameLayout>

            <!-- Slot 3 -->
            <FrameLayout android:layout_width="0dp" android:layout_height="68dp"
                android:layout_weight="1">
                <LinearLayout android:id="@+id/dockSlot3"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:gravity="center" android:background="@drawable/bg_dock_item"
                    android:clickable="true" android:focusable="true">
                    <ImageView android:id="@+id/dockIcon3"
                        android:layout_width="52dp" android:layout_height="52dp"
                        android:scaleType="centerInside"/>
                </LinearLayout>
                <TextView android:id="@+id/dockBadge3"
                    android:layout_width="17dp" android:layout_height="17dp"
                    android:layout_gravity="top|end" android:layout_margin="7dp"
                    android:background="@drawable/bg_badge"
                    android:textColor="#FFFFFF" android:textSize="9sp"
                    android:fontFamily="sans-serif-bold" android:gravity="center"
                    android:visibility="gone"/>
            </FrameLayout>

            <!-- Slot 4 -->
            <FrameLayout android:layout_width="0dp" android:layout_height="68dp"
                android:layout_weight="1">
                <LinearLayout android:id="@+id/dockSlot4"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:gravity="center" android:background="@drawable/bg_dock_item"
                    android:clickable="true" android:focusable="true">
                    <ImageView android:id="@+id/dockIcon4"
                        android:layout_width="52dp" android:layout_height="52dp"
                        android:scaleType="centerInside"/>
                </LinearLayout>
                <TextView android:id="@+id/dockBadge4"
                    android:layout_width="17dp" android:layout_height="17dp"
                    android:layout_gravity="top|end" android:layout_margin="7dp"
                    android:background="@drawable/bg_badge"
                    android:textColor="#FFFFFF" android:textSize="9sp"
                    android:fontFamily="sans-serif-bold" android:gravity="center"
                    android:visibility="gone"/>
            </FrameLayout>

        </LinearLayout>

        <View android:id="@+id/navBarSpacer"
            android:layout_width="match_parent"
            android:layout_height="0dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
