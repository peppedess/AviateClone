<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base bianca traslucente -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#EDFFFFFF"/>
            <corners android:topLeftRadius="26dp" android:topRightRadius="26dp"/>
        </shape>
    </item>
    <!-- Bordo superiore sottile per depth -->
    <item android:bottom="0dp" android:left="0dp" android:right="0dp">
        <shape android:shape="rectangle">
            <stroke android:width="0.5dp" android:color="#28000000"/>
            <corners android:topLeftRadius="26dp" android:topRightRadius="26dp"/>
            <solid android:color="#00000000"/>
        </shape>
    </item>
</layer-list>
